{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "marketflowjournal.com" }],
      "destination": "https://www.marketflowjournal.com/",
      "permanent": true
    },
    {
      "source": "/:path(changelog|roadmap|docs|documentation|guide|import-guide|csv|tutorials|workflows|terms|terms-of-service|privacy|privacy-policy|contact)",
      "has": [{ "type": "host", "value": "marketflowjournal.com" }],
      "destination": "https://www.marketflowjournal.com/:path",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/leaderboard-refresh",
      "schedule": "0 3 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/mt-sync", "destination": "/api/broker-sync?mode=mt" },
    { "source": "/api/mt/sync", "destination": "/api/broker-sync?mode=mt" },
    { "source": "/api/webhook-sync", "destination": "/api/broker-sync?mode=webhook" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": "create-react-app"
}
