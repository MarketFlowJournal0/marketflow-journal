{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.marketflowjournal.com" }],
      "destination": "https://marketflowjournal.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": "create-react-app"
}
