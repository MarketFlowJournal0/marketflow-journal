{
  "crons": [
    {
      "path": "/api/cron/leaderboard-refresh",
      "schedule": "0 3 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.marketflowjournal.com" }],
      "destination": "https://marketflowjournal.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/mt-sync", "destination": "/api/broker-sync?mode=mt" },
    { "source": "/api/mt/sync", "destination": "/api/broker-sync?mode=mt" },
    { "source": "/api/webhook-sync", "destination": "/api/broker-sync?mode=webhook" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": "create-react-app"
}